# =========================================================================
# Hassan — env template. Copy to .env (root) and apps/web/.env.local.
# Never commit real secrets. .env is gitignored.
# =========================================================================

# ----- LLM inference (cascade) -----
GROQ_API_KEY=                       # llama-3.3-70b-versatile, 6k TPM / 30 RPM free
GOOGLE_API_KEY=                     # Gemini 2.5 Flash (long-context, multimodal)
OPENROUTER_API_KEY=                 # free-tier coding bursts (deepseek, llama, gemini)
CEREBRAS_API_KEY=                   # ~2100 tps Llama 3.3 70B speed-burst
TOGETHER_API_KEY=                   # optional Jais hosting
HUGGINGFACE_API_TOKEN=              # Jais-Family-30B-chat via HF Inference

# ----- Voice -----
LIVEKIT_URL=                        # wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=                   # Nova-3 STT trial credits
ELEVENLABS_API_KEY=                 # Arabic TTS

# ----- WhatsApp -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886    # sandbox default

# ----- Memory / vector / cache -----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
REDIS_URL=redis://localhost:6379/0
MEM0_API_KEY=                       # optional cloud; falls back to local

# ----- Observability -----
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ----- Postgres (durable LangGraph checkpoints + audit) -----
POSTGRES_USER=hassan
POSTGRES_PASSWORD=hassan_dev
POSTGRES_DB=hassan
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://hassan:hassan_dev@localhost:5432/hassan

# ----- Local fallback (Ollama) -----
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_FAST=qwen2.5:7b
OLLAMA_MODEL_REASONER=qwen2.5:32b-instruct
OLLAMA_MODEL_ARABIC=jais:13b
OLLAMA_MODEL_EMBED=nomic-embed-text

# ----- Routing policy -----
PRIMARY_LLM=groq:llama-3.3-70b-versatile
ARABIC_LLM=hf:inception/jais-family-30b-chat
LONGCTX_LLM=google:gemini-2.5-flash
FALLBACK_LLM=ollama:qwen2.5:7b

# ----- App -----
APP_ENV=dev
APP_LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
