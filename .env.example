# =========================================================================
# Agent42 — env template. Copy to .env (root) and apps/web/.env.local.
# Never commit real secrets. .env is gitignored.
# =========================================================================

# ----- LLM inference (cascade) -----
GROQ_API_KEY=                       # llama-3.3-70b-versatile, 6k TPM / 30 RPM free
GOOGLE_API_KEY=                     # Gemini 2.5 Flash (long-context, multimodal)
OPENROUTER_API_KEY=                 # free-tier coding bursts (deepseek, llama, gemini)
CEREBRAS_API_KEY=                   # ~2100 tps Llama 3.3 70B speed-burst
TOGETHER_API_KEY=                   # optional Jais hosting
HUGGINGFACE_API_TOKEN=              # Jais-Family-30B-chat via HF Inference

# ----- Voice -----
LIVEKIT_URL=                        # wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=                   # Nova-3 STT trial credits
ELEVENLABS_API_KEY=                 # Arabic TTS

# ----- WhatsApp: Meta Cloud API (primary chatbot — "MOEI Assistant (Demo)") -----
META_WHATSAPP_PHONE_NUMBER_ID=         # WhatsApp > API Setup
META_WHATSAPP_ACCESS_TOKEN=            # System User non-expiring token (or 24h temp to start)
META_WHATSAPP_VERIFY_TOKEN=            # any random string; must match the Meta webhook config
META_APP_SECRET=                       # App > Settings > Basic; validates X-Hub-Signature-256
META_GRAPH_API_VERSION=v22.0           # use the default version shown in the dashboard
META_WHATSAPP_NUMBER=                  # public E.164 number for the "Try on WhatsApp" wa.me link
META_WHATSAPP_WABA_ID=                 # optional; for template management later
# META_SKIP_SIGNATURE_CHECK=1          # local dev only — skip webhook signature validation

# ----- WhatsApp/SMS: Twilio (kept for SMS + dormant WhatsApp fallback) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886    # sandbox default

# ----- Memory / cache -----
REDIS_URL=redis://localhost:6379/0
MEM0_API_KEY=                       # optional cross-channel recall (uv extra: integrations); no-op if unset

# ----- Observability -----
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ----- Postgres (system of record + audit) -----
POSTGRES_USER=hassan
POSTGRES_PASSWORD=hassan_dev
POSTGRES_DB=hassan
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://hassan:hassan_dev@localhost:5432/hassan

# ----- Routing policy (all cloud; last-resort fallback is Groq 70B, see llm/client.py) -----
PRIMARY_LLM=groq:llama-3.3-70b-versatile
ARABIC_LLM=hf:inception/jais-family-30b-chat
LONGCTX_LLM=google:gemini-2.5-flash

# ----- App -----
APP_ENV=dev
APP_LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_EXTRA_ORIGINS=                # comma-separated web/ngrok origins, e.g. https://your-app.vercel.app
DOCUMENT_STORAGE_DIR=storage/customer-documents  # local private upload storage; use S3/Azure Blob in production
